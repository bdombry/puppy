# 🚨 IMPORTANT: All variables must have EXPO_PUBLIC_ prefix to be accessible in React Native
# Expo only exposes variables with this prefix for security reasons

# Supabase Configuration
# Get these from your Supabase project dashboard
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# RevenueCat Configuration (Subscriptions)
# Get this from your RevenueCat dashboard
EXPO_PUBLIC_REVENUE_CAT_API_KEY=sk_your_revenue_cat_key_here

# Expo Configuration
# Get this from your app.json or Expo dashboard
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id_here
